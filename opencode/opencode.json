{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-gemini-auth@latest",
    "@spoons-and-mirrors/subtask2@latest",
    "oh-my-opencode@latest"
  ],
  "model": "anthropic/claude-opus-4-6",
  "permission": {
    "read": {
      "~/.config/opencode/get-shit-done/*": "allow"
    },
    "external_directory": {
      "~/.config/opencode/get-shit-done/*": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "mcp-grafana": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "-e",
        "GRAFANA_URL",
        "-e",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN",
        "grafana/mcp-grafana",
        "-t",
        "stdio"
      ],
      "enabled": true
    },
    "goldfish": {
      "type": "local",
      "command": [
        "/Users/twhitney/.local/bin/goldfish-mcp",
        "--api-url",
        "http://localhost:3100"
      ],
      "enabled": true
    },
    "brave-search": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "BRAVE_API_KEY",
        "docker.io/mcp/brave-search"
      ],
      "enabled": true
    },
    "qdrant-code": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@mhalder/qdrant-mcp-server@latest"
      ],
      "enabled": true,
      "environment": {
        "QDRANT_URL": "http://localhost:6333",
        "EMBEDDING_PROVIDER": "openai",
        "OLLAMA_BASE_URL": "http://localhost:11434",
        "OPENAI_MODEL": "text-embedding-3-small"
      }
    }
  }
}
